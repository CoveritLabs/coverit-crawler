# CoverIt crawler environment
# Copy to .env when running the crawler worker locally.

# Local worker helper. scripts/run_local_worker.py rewrites @db:5432 and
# redis://redis to the host ports below so this file also matches Docker URLs.
POSTGRES_HOST_PORT=15432
DATABASE_URL=postgresql://postgres:postgres@db:5432/coverit?schema=public
REDIS_URL=redis://redis:6379/0
COVERIT_API_INTERNAL_URL=http://localhost:3000/api/v1
COVERIT_API_INTERNAL_WS_URL=ws://localhost:3000/api/v1
INTERNAL_SERVICE_TOKEN=change-me-for-internal-services

# Neo4j. Use bolt://neo4j:7687 inside Docker and localhost when running locally.
# The crawler also accepts API-style NEO4J_URL and NEO4J_USERNAME aliases.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Cloud Neo4j example:
# NEO4J_URI=neo4j+s://example.databases.neo4j.io
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your-cloud-password

# Crawler behavior.
HEADLESS=true
TIMEOUT_MS=3000
MAX_STATES=1000
MAX_TRANSITIONS=5000
MAX_ELEMENTS_PER_STATE=5
MAX_SELECT_OPTIONS_PER_ELEMENT=3
MAX_ACTION_REPEATS_PER_URL=2
ACTION_RETRY_COUNT=1
REPLAY_RETRY_COUNT=1
POPUP_TIMEOUT_MS=3000
DOM_QUIET_MS=400
DOM_SETTLE_TIMEOUT_MS=3000
USE_DOM_QUIESCENCE=true
PAGE_LOAD_STATE=networkidle
CLICK_NON_HTTP_LINKS=true
DEFER_DESTRUCTIVE_ACTIONS=true
DESTRUCTIVE_KEYWORDS=logout,log out,sign out,delete,remove,unsubscribe,cancel,checkout,pay,purchase,order,place order,reset,deactivate,terminate,drop,empty cart,clear cart

# Semantic diversity.
USE_SEMANTIC_DIVERSITY=true
SEMANTIC_DIVERSITY_THRESHOLD=0.90
SEMANTIC_UNCERTAINTY_MARGIN=0.05
SEMANTIC_MAX_BANK_SIZE=1000
SEMANTIC_ARTIFACT_DIR=src/models/semantic

# Queue settings.
CRAWLER_TAG=dev
CRAWL_ARQ_QUEUE_NAME=arq:queue
CRAWL_ARQ_EXPIRES_MS=86400000
CRAWLER_MAX_JOBS=10
CRAWLER_JOB_TIMEOUT_SECONDS=1800
MANUAL_ARQ_QUEUE_NAME=arq:manual-recordings
MANUAL_CRAWLER_MAX_JOBS=2
MANUAL_CRAWLER_JOB_TIMEOUT_SECONDS=7200
MANUAL_SESSION_IDLE_TTL_SECONDS=600
